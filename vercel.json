{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    {
      "src": "/(css|js|images|fonts|favicon.ico)/(.+)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(.+)\\.(.+)$",
      "dest": "/public/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
